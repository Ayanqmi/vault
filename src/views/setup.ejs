<%- include('partials/head', { title: 'Set up vault key' }) %>
<%- include('partials/topbar') %>

<canvas id="starfield" class="starfield"></canvas>

<main class="auth-page">
  <div class="auth-card auth-card--unlock">
    <div class="unlock-icon">
      <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 9.9-1"/></svg>
    </div>

    <h1 class="auth-title">set your vault key</h1>
    <p class="unlock-sub">
      This is your <strong>master encryption password</strong>. All your vault data is encrypted with a key derived from it using PBKDF2. <strong>We never see or store this password.</strong> If you lose it, your data cannot be recovered.
    </p>

    <% if (typeof error !== 'undefined' && error) { %>
      <div class="form-msg form-msg--error"><%= error %></div>
    <% } %>

    <form class="auth-form" id="setupForm">
      <input type="hidden" id="setupCsrf" value="<%= csrfToken %>" />

      <div class="field">
        <label class="field-label" for="vaultKey">vault key</label>
        <div class="field-wrap">
          <input class="field-input" type="password" id="vaultKey" name="vaultKey"
                 autocomplete="new-password" minlength="8" autofocus required />
          <button type="button" class="field-eye" aria-label="Show vault key" data-eye="vaultKey">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
          </button>
        </div>
        <span class="field-hint">minimum 8 characters. use something strong and unique.</span>
      </div>

      <div class="field">
        <label class="field-label" for="vaultKeyConfirm">confirm vault key</label>
        <div class="field-wrap">
          <input class="field-input" type="password" id="vaultKeyConfirm" name="vaultKeyConfirm"
                 autocomplete="new-password" minlength="8" required />
          <button type="button" class="field-eye" aria-label="Show vault key" data-eye="vaultKeyConfirm">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
          </button>
        </div>
      </div>

      <div id="setupError" class="form-msg form-msg--error" style="display:none"></div>

      <div class="strength-bar-wrap">
        <div class="strength-bar" id="strengthBar"></div>
      </div>
      <span class="strength-label" id="strengthLabel"></span>

      <button class="btn btn--primary btn--full" type="submit" id="setupBtn">
        <span id="setupBtnText">create vault</span>
      </button>
    </form>

    <div class="register-note">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
      Write your vault key down somewhere safe. There is no "forgot my vault key" — by design.
    </div>
  </div>
</main>

<%- include('partials/footer') %>
<script src="/crypto.js"></script>
<script src="/setup.js"></script>
