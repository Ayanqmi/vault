<%- include('../partials/head', { title: 'Sign in' }) %>
<%- include('../partials/topbar') %>

<canvas id="starfield" class="starfield"></canvas>

<main class="auth-page">
  <div class="auth-card">
    <div class="auth-logo">
      <img src="/zuhing.webp" alt="" class="logo-img" />
      ayanami<span class="logo-accent">.vault</span>
    </div>
    <h1 class="auth-title">sign in to your vault</h1>
    <p class="auth-sub">Use your <a href="https://ayanami.app" target="_blank" rel="noopener">ayanami.app</a> account.</p>

    <% if (typeof error !== 'undefined' && error) { %>
      <div class="form-msg form-msg--error"><%= error %></div>
    <% } %>
    <% if (typeof info !== 'undefined' && info) { %>
      <div class="form-msg form-msg--info"><%= info %></div>
    <% } %>

    <form class="auth-form" method="POST" action="/auth/login">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <input type="hidden" name="next" value="<%= next %>" />

      <div class="field">
        <label class="field-label" for="identifier">username or email</label>
        <input class="field-input" type="text" id="identifier" name="identifier"
               autocomplete="username" autocapitalize="none" spellcheck="false" autofocus required />
      </div>

      <div class="field">
        <label class="field-label" for="password">password</label>
        <div class="field-wrap">
          <input class="field-input" type="password" id="password" name="password"
                 autocomplete="current-password" required />
          <button type="button" class="field-eye" aria-label="Show password" data-eye="password">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
          </button>
        </div>
      </div>

      <button class="btn btn--accent btn--full" type="submit">sign in</button>
    </form>

    <p class="auth-alt">no account? <a href="https://ayanami.app/auth/register" target="_blank" rel="noopener">register at ayanami.app</a></p>
  </div>
</main>

<%- include('../partials/footer') %>
