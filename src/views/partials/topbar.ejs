<header class="topbar">
  <a href="/" class="topbar-logo">
    <svg class="logo-img" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
    <span class="logo-text">ayanami<span class="logo-accent">.vault</span></span>
  </a>

  <% if (typeof user !== 'undefined' && user) { %>
  <button class="burger" id="burgerBtn" aria-label="Menu" aria-expanded="false">
    <span></span><span></span><span></span>
  </button>
  <nav class="topbar-nav" id="topbarNav">
    <a href="/vault" class="nav-link">
      <svg class="nav-icon nav-icon--lock" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
      <span class="nav-label">vault</span>
    </a>
    <span class="nav-sep"></span>
    <span class="nav-username"><%= user.username || user.email %></span>
    <form action="/auth/logout" method="POST" class="inline-form">
      <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>" />
      <button type="submit" class="nav-btn nav-btn--account">
        <svg class="nav-icon nav-icon--logout" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
        <span class="nav-label">logout</span>
      </button>
    </form>
  </nav>
  <% } else { %>
  <nav class="topbar-nav" id="topbarNav">
    <a href="/auth/login" class="nav-link nav-link--account">
      <svg class="nav-icon nav-icon--login" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" y1="12" x2="3" y2="12"/></svg>
      <span class="nav-label">sign in</span>
    </a>
  </nav>
  <% } %>
</header>
